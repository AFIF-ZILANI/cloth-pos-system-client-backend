// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  STAFF
}

enum SaleStatus {
  COMPLETED
  PARTIALLY_RETURNED
  FULLY_RETURNED
  VOID
}

enum PaymentMethod {
  CASH
  BKASH
  CARD
}

enum PaymentStatus {
  PAID
  PENDING
  REFUNDED
}

enum StockMovementType {
  PURCHASE
  SALE
  SALE_RETURN
  ADJUSTMENT
}

enum StockDirection {
  IN
  OUT
}

// ─────────────────────────────────────────────────────────────────────────────
// Users
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String  @id @default(uuid())
  name          String?
  email         String  @unique
  password_hash String
  refresh_token String?
  phone         String? @unique
  role          Role    @default(OWNER)
  is_active     Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  sales            Sale[]
  purchases        Purchase[]
  saleReturns      SaleReturn[]
  stockAdjustments StockAdjustment[]

  @@index([email])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// Customers
// ─────────────────────────────────────────────────────────────────────────────

model Customer {
  id             String  @id @default(uuid())
  name           String?
  phone          String? @unique
  address        String?
  credit_balance Decimal @default(0) @db.Decimal(10, 2)
  is_active      Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  sales Sale[]

  @@index([phone])
  @@map("customers")
}

// ─────────────────────────────────────────────────────────────────────────────
// Products & Variants
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String?
  parent_id   String?
  is_active   Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  parent   Category?  @relation("CategoryHierarchy", fields: [parent_id], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@index([parent_id])
  @@map("categories")
}

model Product {
  id             String  @id @default(uuid())
  name           String
  normalized_key String // lowercased+stripped for duplicate detection
  description    String?
  category_id    String
  is_active      Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  category Category         @relation(fields: [category_id], references: [id])
  variants ProductVariant[]

  @@index([category_id])
  @@index([normalized_key])
  @@map("products")
}

model ProductVariant {
  id          String  @id @default(uuid())
  product_id  String
  product_ref Int     @unique @default(autoincrement()) // short numeric POS lookup code
  sku         String  @unique
  barcode     String? @unique
  name        String? // e.g. "Red / XL" — null if product has only one variant
  color       String?
  size        String?

  cost_price Decimal @db.Decimal(10, 2)
  sell_price Decimal @db.Decimal(10, 2)
  is_active  Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  product Product @relation(fields: [product_id], references: [id])

  saleItems            SaleItem[]
  purchaseItems        PurchaseItem[]
  saleReturnItems      SaleReturnItem[]
  stockAdjustmentItems StockAdjustmentItem[]
  stockLedgers         StockLedger[]

  @@index([product_id])
  @@index([sku])
  @@index([barcode])
  @@index([product_ref])
  @@map("product_variants")
}

// ─────────────────────────────────────────────────────────────────────────────
// Sales
// ─────────────────────────────────────────────────────────────────────────────

model Sale {
  id          String  @id @default(uuid())
  invoice_no  String  @unique
  user_id     String
  customer_id String?

  subtotal        Decimal    @db.Decimal(10, 2)
  discount_amount Decimal    @default(0) @db.Decimal(10, 2)
  tax_amount      Decimal    @default(0) @db.Decimal(10, 2)
  total           Decimal    @db.Decimal(10, 2)
  status          SaleStatus @default(COMPLETED)
  note            String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user     User      @relation(fields: [user_id], references: [id])
  customer Customer? @relation(fields: [customer_id], references: [id])

  items        SaleItem[]
  payments     Payment[]
  returns      SaleReturn[]
  stockLedgers StockLedger[]

  @@index([user_id])
  @@index([customer_id])
  @@index([created_at])
  @@index([invoice_no])
  @@map("sales")
}

model SaleItem {
  id         String @id @default(uuid())
  sale_id    String
  variant_id String

  quantity        Int
  unit_price      Decimal @db.Decimal(10, 2) // price at time of sale (snapshot)
  discount_amount Decimal @default(0) @db.Decimal(10, 2)
  total           Decimal @db.Decimal(10, 2)

  sale    Sale           @relation(fields: [sale_id], references: [id])
  variant ProductVariant @relation(fields: [variant_id], references: [id])

  @@index([sale_id])
  @@index([variant_id])
  @@map("sale_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// Payments
// ─────────────────────────────────────────────────────────────────────────────

model Payment {
  id      String @id @default(uuid())
  sale_id String

  method    PaymentMethod
  amount    Decimal       @db.Decimal(10, 2)
  status    PaymentStatus @default(PAID)
  reference String? // bKash TrxID, card auth code, etc.

  created_at DateTime @default(now())

  sale Sale @relation(fields: [sale_id], references: [id])

  @@index([sale_id])
  @@map("payments")
}

// ─────────────────────────────────────────────────────────────────────────────
// Returns
// ─────────────────────────────────────────────────────────────────────────────

model SaleReturn {
  id      String @id @default(uuid())
  sale_id String
  user_id String

  reason String?
  total  Decimal @db.Decimal(10, 2)

  created_at DateTime @default(now())

  sale Sale @relation(fields: [sale_id], references: [id])
  user User @relation(fields: [user_id], references: [id])

  items        SaleReturnItem[]
  stockLedgers StockLedger[]

  @@index([sale_id])
  @@index([user_id])
  @@map("sale_returns")
}

model SaleReturnItem {
  id         String @id @default(uuid())
  return_id  String
  variant_id String

  quantity   Int
  unit_price Decimal @db.Decimal(10, 2)
  total      Decimal @db.Decimal(10, 2)

  saleReturn SaleReturn     @relation(fields: [return_id], references: [id])
  variant    ProductVariant @relation(fields: [variant_id], references: [id])

  @@index([return_id])
  @@index([variant_id])
  @@map("sale_return_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// Purchasing
// ─────────────────────────────────────────────────────────────────────────────

model Supplier {
  id    String  @id @default(uuid())
  name  String
  phone String? @unique
  email String? @unique

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  purchases Purchase[]

  @@map("suppliers")
}

model Purchase {
  id          String  @id @default(uuid())
  supplier_id String?
  user_id     String

  total Decimal @db.Decimal(10, 2)
  note  String?

  created_at DateTime @default(now())

  supplier Supplier? @relation(fields: [supplier_id], references: [id])
  user     User      @relation(fields: [user_id], references: [id])

  items        PurchaseItem[]
  stockLedgers StockLedger[]

  @@index([supplier_id])
  @@index([user_id])
  @@index([created_at])
  @@map("purchases")
}

model PurchaseItem {
  id          String @id @default(uuid())
  purchase_id String
  variant_id  String

  quantity   Int
  cost_price Decimal @db.Decimal(10, 2) // price at time of purchase (snapshot)
  total      Decimal @db.Decimal(10, 2)

  purchase Purchase       @relation(fields: [purchase_id], references: [id])
  variant  ProductVariant @relation(fields: [variant_id], references: [id])

  @@index([purchase_id])
  @@index([variant_id])
  @@map("purchase_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// Stock Adjustments
// ─────────────────────────────────────────────────────────────────────────────

model StockAdjustment {
  id          String @id @default(uuid())
  adjusted_by String

  reason String?
  note   String?

  created_at DateTime @default(now())

  adjustedByUser User @relation(fields: [adjusted_by], references: [id])

  items        StockAdjustmentItem[]
  stockLedgers StockLedger[]

  @@index([adjusted_by])
  @@map("stock_adjustments")
}

model StockAdjustmentItem {
  id            String @id @default(uuid())
  adjustment_id String
  variant_id    String

  direction StockDirection
  quantity  Int
  note      String?

  adjustment StockAdjustment @relation(fields: [adjustment_id], references: [id])
  variant    ProductVariant  @relation(fields: [variant_id], references: [id])

  @@index([adjustment_id])
  @@index([variant_id])
  @@map("stock_adjustment_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// Stock Ledger  (append-only, never update or delete rows)
// ─────────────────────────────────────────────────────────────────────────────

model StockLedger {
  id         String @id @default(uuid())
  variant_id String

  type          StockMovementType
  direction     StockDirection
  quantity      Int
  balance_after Int // running stock snapshot — set at write time

  // Exactly one of these will be non-null per row
  sale_id       String?
  purchase_id   String?
  return_id     String?
  adjustment_id String?

  created_at DateTime @default(now())

  variant    ProductVariant   @relation(fields: [variant_id], references: [id])
  sale       Sale?            @relation(fields: [sale_id], references: [id])
  purchase   Purchase?        @relation(fields: [purchase_id], references: [id])
  saleReturn SaleReturn?      @relation(fields: [return_id], references: [id])
  adjustment StockAdjustment? @relation(fields: [adjustment_id], references: [id])

  @@index([variant_id])
  @@index([variant_id, created_at])
  @@index([sale_id])
  @@index([purchase_id])
  @@index([return_id])
  @@index([adjustment_id])
  @@map("stock_ledgers")
}
